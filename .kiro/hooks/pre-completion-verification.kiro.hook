{
  "name": "Pre-Completion Verification",
  "version": "1.0.0",
  "description": "Manually triggered full verification: runs npm test, npm run build, and npm run check before completing or committing work. Kept manual (not on-save) so the suite does not run on every file save.",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "npm test && npm run build && npm run check"
  }
}
