{
  "name": "No-Network Test Guard Reminder",
  "version": "1.0.0",
  "description": "When provider/workflow/extension/sandbox tests are added or edited, remind the agent to keep tests provider-free: mock fetch, assert no network, require no API keys, disabled by default.",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "tests/providers.test.ts",
      "tests/llmProviders.test.ts",
      "tests/workflows.test.ts",
      "tests/extensions.test.ts",
      "tests/safeCodeExecution.test.ts",
      "tests/adapters.test.ts"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A provider/workflow/extension/sandbox test changed. Verify it stays provider-free: mock fetch (no real network), assert no network where appropriate, require no API keys, and keep external behavior disabled by default. If live-provider behavior is exercised, it must be opt-in via an explicit env flag and skip (not fail) when the key is missing."
  }
}
