{
  "name": "Issue Catalog Drift Check",
  "version": "1.0.0",
  "description": "When the roadmap issue catalog or its generator changes, run the deterministic drift check to ensure generated drafts are in sync.",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "docs/issues/roadmap-issues.json",
      "scripts/generate-roadmap-issues.js"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "node scripts/generate-roadmap-issues.js --check"
  }
}
