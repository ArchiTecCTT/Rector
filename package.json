{
  "name": "rector",
  "version": "0.1.0",
  "description": "Chat-first AI engineering orchestration.",
  "private": false,
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./extensions": {
      "types": "./dist/extensions/index.d.ts",
      "import": "./dist/extensions/index.js"
    },
    "./sandbox": {
      "types": "./dist/sandbox/index.d.ts",
      "import": "./dist/sandbox/index.js"
    },
    "./workflows": {
      "types": "./dist/workflows/index.d.ts",
      "import": "./dist/workflows/index.js"
    },
    "./deployment": {
      "types": "./dist/deployment/index.d.ts",
      "import": "./dist/deployment/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/bin/server.ts",
    "benchmark": "tsx src/bin/benchmark.ts",
    "benchmark:performance": "tsx scripts/performance-baseline.ts",
    "build": "tsc && node scripts/fix-dist-esm-imports.js",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:tidb": "tsx --env-file=.env scripts/tidb-smoke-test.ts",
    "smoke:memory": "tsx --env-file=.env scripts/memory-live-smoke-test.ts",
    "test:coverage": "vitest run --coverage --testTimeout=10000 --maxWorkers=2"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "overrides": {
    "esbuild": ">=0.28.1"
  },
  "dependencies": {
    "express": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@vitest/coverage-v8": "^4.1.8",
    "fast-check": "^4.8.0",
    "supertest": "^6.3.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.8"
  }
}
