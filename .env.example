# === Rector Local-First MVP -- Environment Variables ===

# --- Core ---
NODE_ENV=development
PORT=3000
DOPPLER_TOKEN=

# --- Deployment Prototype (docs/config only; no deploy actions) ---
DEPLOYMENT_TARGET=local
PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000
HEROKU_APP_NAME=
HEROKU_RELEASE_VERSION=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PROJECT_NAME=
CLOUDFLARE_PROXY_ENABLED=false

# --- Kafka / Confluent Cloud (future production mode) ---
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=rector-local
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_SSL=false

# --- MongoDB Atlas / Redis (future production mode) ---
MONGO_URI=mongodb://localhost:27017/rector
MONGO_DB=rector_core
REDIS_URL=redis://localhost:6379

# --- Generic OpenAI-compatible LLM ---
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
FLAGSHIP_MODEL=gpt-4o
SLM_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct

# --- Together AI SLMs ---
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1

# --- Azure OpenAI flagship option ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# --- AWS Bedrock flagship option ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Sandbox / Validation ---
SANDBOX_RUNTIME=local
DEPOT_API_KEY=
SENTRY_DSN=
CODECOV_TOKEN=
CODESCENE_TOKEN=

# --- Vector Memory / Research ---
CHROMA_URL=http://localhost:8000
CHROMA_API_KEY=
PERPLEXITY_API_KEY=

# --- Linear / Make ---
LINEAR_API_KEY=
LINEAR_TEAM_ID=
LINEAR_BASE_URL=https://api.linear.app/graphql
LINEAR_WEBHOOK_SECRET=
MAKE_WEBHOOK_URL=
MAKE_WEBHOOK_SECRET=
# External workflow adapters remain network-disabled by default in local alpha.
WORKFLOW_INTEGRATIONS_ENABLE_NETWORK=false

# --- Telemetry ---
TELEMETRY_BACKEND=local
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
DATADOG_API_KEY=
DATADOG_SITE=datadoghq.com
NEW_RELIC_LICENSE_KEY=
AMPLITUDE_API_KEY=
