# === Rector Environment Variables ===
#
# **Hassle-free preferred path (new vision):** Configure everything (LLM providers, memory database
# backends like local/Mem0/TiDB Cloud, sandbox, etc.) through the web UI. This uses
# .rector/providers.json + .rector/secrets.enc (and future equivalent for memory/persistence config).
# No need to edit this file or set most env vars for normal use.
#
# Local mode (ORCHESTRATOR_MODE=local) is the perfect regression baseline: it ignores cloud/UI config,
# performs zero network calls, and is used for `npm test` / safe development. It must remain identical
# regardless of UI or cloud settings.
#
# This file is primarily for advanced/local fallback, CI, or contributor setups.

# --- Core ---
NODE_ENV=development
PORT=3000
HOST=127.0.0.1
DOPPLER_TOKEN=

# --- BYOK Orchestration (ORN-31..34) ---
# local (default / regression baseline): provider-free, zero network, zero cost -- the npm test baseline.
#   UI config and most cloud keys below are ignored in local mode.
# external: live providers, real sandbox, durable options via UI-managed config + this as fallback.
ORCHESTRATOR_MODE=local

# External mode reuses provider keys from the LLM sections below (or preferably the UI stores).
# Cloudflare Workers AI needs an API token alongside CLOUDFLARE_ACCOUNT_ID.
CLOUDFLARE_API_TOKEN=

# --- In-app configuration (UI-managed; strongly preferred) ---
# Providers, routes, and (future) memory/persistence backends are configured via the web UI.
# Persisted to .rector/providers.json (non-secret) + .rector/secrets.enc (encrypted).
# This is the hassle-free path for cloud/VPS use. Local mode is unaffected.
#
# Memory database providers (user vision): selectable via UI (local in-memory/SQLite, Mem0, TiDB Cloud, etc.).
# The system is designed to be pluggable and non-rigid here — configuration should not require
# editing files.
#
# PRECEDENCE: UI config takes precedence. Env vars below are fallback.
# Local_Mode (ORCHESTRATOR_MODE=local): persisted/UI config never causes provider/network calls.
# See tests for regression pinning and cloud-capable-transition spec for details.

# --- Deployment Prototype (docs/config only; no deploy actions) ---
DEPLOYMENT_TARGET=local
PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000
HEROKU_APP_NAME=
HEROKU_RELEASE_VERSION=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PROJECT_NAME=
CLOUDFLARE_PROXY_ENABLED=false

# --- Kafka / Confluent Cloud (future production mode) ---
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=rector-local
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_SSL=false

# --- MongoDB Atlas / Redis (future production mode) ---
MONGO_URI=mongodb://localhost:27017/rector
MONGO_DB=rector_core
REDIS_URL=redis://localhost:6379

# --- Persistence driver (ORN-39) ---
# memory (default): in-memory provider-free baseline used by the test suite.
# sqlite: local file-backed store (no cloud account, no network) -- the local product default.
# tidb: optional hosted TiDB Cloud path; never auto-selected. See docs/deployment/tidb-smoke-test.md.
RECTOR_PERSISTENCE=memory
RECTOR_SQLITE_PATH=.rector/rector.db
# TiDB Cloud connection block. Only read when RECTOR_PERSISTENCE=tidb (or by the manual
# `npm run smoke:tidb` smoke test, which forces the tidb driver). Leave blank for local use.
TIDB_HOST=
TIDB_PORT=4000
TIDB_USER=
TIDB_PASSWORD=
TIDB_DATABASE=
TIDB_TLS=true

# --- Generic OpenAI-compatible LLM ---
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
FLAGSHIP_MODEL=gpt-4o
SLM_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct

# --- Together AI SLMs ---
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1

# --- Azure OpenAI flagship option ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# --- AWS Bedrock flagship option ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Sandbox / Validation ---
SANDBOX_RUNTIME=local
DEPOT_API_KEY=
SENTRY_DSN=
CODECOV_TOKEN=
CODESCENE_TOKEN=

# --- Vector Memory / Research ---
# Mem0 cloud memory (optional). Only used when Mem0 is selected as the active memory
# provider or when running the manual opt-in live checks:
#   npm test -- tests/memoryLive.integration.test.ts
#   npm run smoke:memory
# Requires optional package: npm install mem0ai
MEM0_API_KEY=
# Chroma vector memory endpoint (optional). Used by the Chroma memory provider and
# the manual opt-in live checks above. Requires optional package: npm install chromadb
CHROMA_URL=http://localhost:8000
# Optional Chroma auth token when the server requires token-based authentication.
CHROMA_API_KEY=

# --- Linear / Make ---
LINEAR_API_KEY=
LINEAR_TEAM_ID=
LINEAR_BASE_URL=https://api.linear.app/graphql
LINEAR_WEBHOOK_SECRET=
MAKE_WEBHOOK_URL=
MAKE_WEBHOOK_SECRET=
# External workflow adapters remain network-disabled by default in local alpha.
WORKFLOW_INTEGRATIONS_ENABLE_NETWORK=false

# --- Telemetry ---
TELEMETRY_BACKEND=local
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
DATADOG_API_KEY=
DATADOG_SITE=datadoghq.com
NEW_RELIC_LICENSE_KEY=
AMPLITUDE_API_KEY=
