# === Rector Local-First MVP -- Environment Variables ===

# --- Core ---
NODE_ENV=development
PORT=3000
HOST=127.0.0.1
DOPPLER_TOKEN=

# --- BYOK Orchestration (ORN-31..34) ---
# local (default): provider-free planner, zero network, zero cost -- the npm test baseline.
# external: live planner via a BYOK provider; requires at least one configured provider below.
ORCHESTRATOR_MODE=local
# External mode reuses provider keys from the LLM sections below. Cloudflare Workers AI needs an
# API token alongside CLOUDFLARE_ACCOUNT_ID (see Deployment Prototype):
CLOUDFLARE_API_TOKEN=

# --- In-app BYOK provider configuration (UI-managed; preferred over the .env keys below) ---
# Providers can now be configured, tested, and selected from the browser instead of editing
# this file. That flow persists locally and is read by the Config_Bridge at provider build time:
#   - Non-secret config (kind, label, base URL, model ids, active-route map) -> Provider_Config_Store
#     at .rector/providers.json. NEVER contains a secret value; secrets are referenced by secretRef only.
#   - API keys -> encrypted Secret_Store at .rector/secrets.enc (AES-256-GCM). The API exposes only a
#     `secretPresent` boolean; key values are never returned to the browser or written to providers.json.
#   - Any OpenAI-compatible endpoint (base URL + key + model) is supported via the openai-compatible adapter.
#
# PRECEDENCE (Req 13.4): for a given provider/field, persisted UI configuration takes precedence over the
# corresponding process.env value below; the env vars act as the fallback for fields the UI did not set.
# This precedence is deterministic and applies identically to provider construction and the connection test.
#
# Local_Mode is unaffected by any of the above: with ORCHESTRATOR_MODE=local, persisted config and secrets
# never cause a provider or network call (regression-pinned by tests/localModeInvariance.test.ts).

# --- Deployment Prototype (docs/config only; no deploy actions) ---
DEPLOYMENT_TARGET=local
PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000
HEROKU_APP_NAME=
HEROKU_RELEASE_VERSION=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PROJECT_NAME=
CLOUDFLARE_PROXY_ENABLED=false

# --- Kafka / Confluent Cloud (future production mode) ---
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=rector-local
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_SSL=false

# --- MongoDB Atlas / Redis (future production mode) ---
MONGO_URI=mongodb://localhost:27017/rector
MONGO_DB=rector_core
REDIS_URL=redis://localhost:6379

# --- Persistence driver (ORN-39) ---
# memory (default): in-memory provider-free baseline used by the test suite.
# sqlite: local file-backed store (no cloud account, no network) -- the local product default.
# tidb: optional hosted TiDB Cloud path; never auto-selected. See docs/deployment/tidb-smoke-test.md.
RECTOR_PERSISTENCE=memory
RECTOR_SQLITE_PATH=.rector/rector.db
# TiDB Cloud connection block. Only read when RECTOR_PERSISTENCE=tidb (or by the manual
# `npm run smoke:tidb` smoke test, which forces the tidb driver). Leave blank for local use.
TIDB_HOST=
TIDB_PORT=4000
TIDB_USER=
TIDB_PASSWORD=
TIDB_DATABASE=
TIDB_TLS=true

# --- Generic OpenAI-compatible LLM ---
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
FLAGSHIP_MODEL=gpt-4o
SLM_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct

# --- Together AI SLMs ---
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1

# --- Azure OpenAI flagship option ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# --- AWS Bedrock flagship option ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Sandbox / Validation ---
SANDBOX_RUNTIME=local
DEPOT_API_KEY=
SENTRY_DSN=
CODECOV_TOKEN=
CODESCENE_TOKEN=

# --- Vector Memory / Research ---
CHROMA_URL=http://localhost:8000
CHROMA_API_KEY=

# --- Linear / Make ---
LINEAR_API_KEY=
LINEAR_TEAM_ID=
LINEAR_BASE_URL=https://api.linear.app/graphql
LINEAR_WEBHOOK_SECRET=
MAKE_WEBHOOK_URL=
MAKE_WEBHOOK_SECRET=
# External workflow adapters remain network-disabled by default in local alpha.
WORKFLOW_INTEGRATIONS_ENABLE_NETWORK=false

# --- Telemetry ---
TELEMETRY_BACKEND=local
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
DATADOG_API_KEY=
DATADOG_SITE=datadoghq.com
NEW_RELIC_LICENSE_KEY=
AMPLITUDE_API_KEY=
